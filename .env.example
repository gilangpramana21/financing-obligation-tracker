# LLM API Keys
# Gemini (FREE - default, recommended)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (PAID - optional alternative)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email Notification Configuration
# SMTP Server (Gmail example)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Sender Email (your email)
SENDER_EMAIL=your-email@gmail.com

# Sender Password (use App Password for Gmail)
# Generate at: https://myaccount.google.com/apppasswords
SENDER_PASSWORD=your-app-password-here

# Recipient Emails (comma-separated for multiple recipients)
RECIPIENT_EMAILS=finance-team@company.com,manager@company.com

